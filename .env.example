# ============================================================
# .env.example — 운영 .env 18키 동기화 버전 (2026-05-15)
# ============================================================
# 이 파일은 시크릿 값을 포함하지 않습니다. 키 이름과 형식 안내용입니다.
# 새 머신 셋업 시 이 파일을 복사해서 .env로 만들고 실제 값을 채워주세요.
# .env 파일은 .gitignore에 반드시 포함되어야 합니다 (현재 보호 중).

# ============================================================
# Telegram (봇별 토큰 4개 + 공통 chat ID)
# ============================================================
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_SISYPHE_BOT_TOKEN=                  # @sisyphe-bot (펀드/일상)
TELEGRAM_RA_SISYPHE_BOT_TOKEN=               # @ra_sisyphe_bot (리서치 알림)
TELEGRAM_RESEARCH_NOTES_BOT_TOKEN=           # @research_notes_bot
TELEGRAM_RESEARCH_BOT_TOKEN=                 # @research_bot (보조)

# ============================================================
# Notion API (봇별 분리 — 키와 DB 각각 별개)
# ============================================================
NOTION_API_KEY=ntn_xxx                       # Research Notes 봇용
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_EARNINGS_API_KEY=ntn_xxx              # Earnings 봇용 (분리 필수)
NOTION_EARNINGS_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================================
# Anthropic (Claude API) — research-notes-bot 일일요약
# ============================================================
ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================================
# Google Sheets / Drive — Service Account
# ============================================================
# 옵션 1: JSON 전체를 한 줄로 (escape 처리 필요)
# 옵션 2: 별도 JSON 파일 경로 (예: extreme-height-486504-c4-*.json)
GOOGLE_SERVICE_ACCOUNT_KEY=

# ============================================================
# GitHub Personal Access Token — repo 자동 push/pull
# ============================================================
GH_PAT=github_pat_xxx

# ============================================================
# Finnhub — earnings-bot 데이터 소스
# ============================================================
FINNHUB_API_KEY=

# ============================================================
# KRX (한국거래소) — pykrx 로그인용
# ============================================================
KRX_ID=
KRX_PW=

# ============================================================
# Naver — 검색/Open API
# ============================================================
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ============================================================
# DART (전자공시)
# ============================================================
DART_API_KEY=

# ============================================================
# Obsolete (제거됨) — 참고용
# ============================================================
# TELEGRAM_TOKEN          → 봇별 토큰 4종으로 대체됨
# TWITTER_USER/PASS/EMAIL → twscrape 코드 잔존하나 실제 미사용 (2026-05-15 확인)
# TARGET_ACCOUNTS         → 트위터 감시 계정 (위와 동일)
