# Antigravity 대시보드 로컬 정적 서빙 (웹서빙 설계 W6)
# 입구는 tailscale serve 프록시뿐 — 127.0.0.1 바인딩 고정.
{
	admin off
	auto_https off
}

# ★사이트 주소는 호스트 무관(:8377) — tailscale serve 프록시가 Host를 ts.net으로 보내므로
#   127.0.0.1:8377로 쓰면 호스트 불일치→빈 200 (2026-07-11 실측). 바인딩은 bind로 루프백 고정.
http://:8377 {
	bind 127.0.0.1
	encode gzip
	@fresh path / *.html *.json *.csv /sisyphe /sisyphe/
	header @fresh Cache-Control "no-cache"

	# Datalake 문답 위키 — AoE 'Wiki' 탭 (2026-07-12 통합, FastAPI 127.0.0.1:8787 프록시)
	redir /wiki /wiki/ 301
	handle_path /wiki/* {
		reverse_proxy 127.0.0.1:8787
	}

	# Watchlist 관심종목 시세판 (2026-07-15) — quoteboard/server.py 데몬(127.0.0.1:8778) 프록시.
	# ★2026-07-16 사용자 확정: AoE 기본화면 = Memento. 루트(/)와 구 랜딩(/index.html) 모두
	#   /sisyphe/memento.html 로 리다이렉트 — 랜딩 페이지 폐지(파일은 잡들이 계속 생성하나 접근 불가).
	redir / /sisyphe/memento.html 302
	redir /index.html /sisyphe/memento.html 302
	redir /watchlist /watchlist/ 301
	handle_path /watchlist/* {
		header Cache-Control "no-store"
		reverse_proxy 127.0.0.1:8778
	}

	# Journal 개인 투자일지 차트 (2026-07-13) — 테일넷+비밀번호(basic_auth) 이중.
	#   데이터·자격증명·페이지 전부 ~/Journal 로컬 전용 — git/게시 파이프라인과 격리 (전역 CLAUDE.md Journal 섹션).
	#   ★~/Journal/caddy_auth.snippet 없으면 caddy 기동 실패 — Journal 폴더 이동 시 이 라우트 먼저 수정.
	redir /journal /journal/ 301
	handle_path /journal/* {
		import /Users/sisyphe/Journal/caddy_auth.snippet
		header Cache-Control "no-store"
		root * /Users/sisyphe/Journal/web
		file_server
	}

	# Sisyphe Ledger 'Plan' API (2026-07-15) — 자금계획 JSON(~/Journal/plan_web.json, 계좌번호 포함).
	#   테일넷 + journal 동일 basic_auth 이중. 백엔드=~/Journal/scripts/plan_api.py (127.0.0.1:8790, launchd com.antigravity.plan-api).
	handle_path /plan-api/* {
		header Cache-Control "no-store"
		reverse_proxy 127.0.0.1:8790
	}

	# Sisyphe 개인 대시보드 (가계부·운동·투자일지) — 2026-07-13 평문 전환.
	#   compose_personal_view.py 가 평문 3페이지를 게시 스냅숏 current/sisyphe/ 로 합성 → 아래 fallback handle 이 서빙.
	#   (이전: staticrypt 암호화본 직서빙 handle_path. 테일넷 한정이라 암호 프롬프트 제거가 목적.)
	handle {
		root * /Users/sisyphe/srv/dashboard/current
		file_server
	}
	log {
		output file /Users/sisyphe/srv/dashboard/logs/access.log {
			roll_size 20MiB
			roll_keep 5
		}
	}
}
