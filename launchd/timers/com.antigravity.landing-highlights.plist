<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.antigravity.landing-highlights</string>
    <key>UserName</key>
    <string>__MACMINI_USER__</string>
    <key>WorkingDirectory</key>
    <string>__REPO__</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__REPO__/launchd/timers/run_timer_job.sh</string>
        <string>landing-highlights</string>
    </array>
    <!-- 데몬 환경 표준 (CONTRACT v3): launchd 는 로그인 환경이 없음 → HOME/PATH/LANG 명시 -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/__MACMINI_USER__</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
    </dict>
    <!-- KST 18:35 매일 (원본: OnCalendar=*-*-* 18:35:00 Asia/Seoul, RandomizedDelaySec=60).
         launchd에는 RandomizedDelaySec 등가물이 없음 → 지터(≤60s) 생략, 18:35 정각 실행. 단일 잡이라 영향 없음. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>18</integer>
        <key>Minute</key>
        <integer>35</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>__REPO__/logs/launchd/landing-highlights.out</string>
    <key>StandardErrorPath</key>
    <string>__REPO__/logs/launchd/landing-highlights.err</string>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
