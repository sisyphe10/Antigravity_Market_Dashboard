<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.antigravity.etf-collect-retry</string>
    <key>UserName</key>
    <string>__MACMINI_USER__</string>
    <key>WorkingDirectory</key>
    <string>__REPO__</string>
    <!-- 원본 etf-collect-retry.timer는 별도 서비스 없이 etf-collect.service를 재트리거 →
         run_timer_job.sh 안에서 etf-collect-retry가 etf-collect와 동일한 run_etf_collect.sh 로 매핑됨.
         collect_etf_daily.py는 재개형(ok>=1000이면 idempotent no-op)이라 안전. stamp는 자기 이름으로 별도 기록. -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__REPO__/launchd/timers/run_timer_job.sh</string>
        <string>etf-collect-retry</string>
    </array>
    <!-- 데몬 환경 표준 (CONTRACT v3): launchd 는 로그인 환경이 없음 → HOME/PATH/LANG 명시 -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/__MACMINI_USER__</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
    </dict>
    <!-- KST 18:00 매일 (원본: OnCalendar=*-*-* 18:00:00 Asia/Seoul). 시스템 TZ=Asia/Seoul 전제. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>18</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>__REPO__/logs/launchd/etf-collect-retry.out</string>
    <key>StandardErrorPath</key>
    <string>__REPO__/logs/launchd/etf-collect-retry.err</string>
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
